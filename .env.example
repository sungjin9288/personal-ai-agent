# Personal AI Agent local configuration example
#
# Copy this file to .env only if you use a local dotenv loader or manually export
# values in your shell. The runtime reads process.env directly and does not load
# .env automatically.
#
# The default stub provider and `npm run demo:local` do not require secrets.

# Local web console
PERSONAL_AI_AGENT_UI_HOST=127.0.0.1
PERSONAL_AI_AGENT_UI_PORT=4317
PERSONAL_AI_AGENT_ROOT=
PERSONAL_AI_AGENT_DEFAULT_ROLE=viewer

# Optional web auth / RBAC / tenant controls
PERSONAL_AI_AGENT_WEB_AUTH_MODE=disabled
PERSONAL_AI_AGENT_WEB_AUTH_TOKEN=
PERSONAL_AI_AGENT_RBAC_MODE=disabled
PERSONAL_AI_AGENT_OIDC_ISSUER=
PERSONAL_AI_AGENT_OIDC_AUDIENCE=
PERSONAL_AI_AGENT_OIDC_JWKS_URL=
PERSONAL_AI_AGENT_OIDC_ROLE_CLAIM=role
PERSONAL_AI_AGENT_TENANT_MODE=disabled
PERSONAL_AI_AGENT_TENANT_CLAIM=tenant_id

# Optional document conversion
PERSONAL_AI_AGENT_MARKITDOWN_BIN=

# Optional local semantic retrieval. Default lexical mode does not start a process.
PERSONAL_AI_AGENT_RETRIEVAL_MODE=lexical
PERSONAL_AI_AGENT_EMBEDDING_COMMAND=
PERSONAL_AI_AGENT_EMBEDDING_ARGS_JSON=[]

# OpenAI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_PROBE_TIMEOUT_MS=8000
OPENAI_RUN_TIMEOUT_MS=45000
OPENAI_INPUT_COST_PER_1M_USD=
OPENAI_OUTPUT_COST_PER_1M_USD=

# Anthropic provider
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MAX_TOKENS=2048
ANTHROPIC_INPUT_COST_PER_1M_USD=
ANTHROPIC_OUTPUT_COST_PER_1M_USD=

# OpenAI-compatible local provider
LOCAL_PROVIDER_MODEL=
LOCAL_PROVIDER_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_PROVIDER_API_KEY=
LOCAL_PROVIDER_MAX_TOKENS=2048
LOCAL_PROVIDER_PROBE_TIMEOUT_MS=5000
LOCAL_PROVIDER_RUN_TIMEOUT_MS=15000
LOCAL_INPUT_COST_PER_1M_USD=
LOCAL_OUTPUT_COST_PER_1M_USD=

# Hermes-compatible provider
HERMES_PROVIDER_MODEL=
HERMES_PROVIDER_BASE_URL=http://127.0.0.1:8000/v1
HERMES_PROVIDER_API_KEY=
HERMES_PROVIDER_MAX_TOKENS=2048
HERMES_PROVIDER_PROBE_TIMEOUT_MS=5000
HERMES_PROVIDER_RUN_TIMEOUT_MS=30000
HERMES_INPUT_COST_PER_1M_USD=
HERMES_OUTPUT_COST_PER_1M_USD=
